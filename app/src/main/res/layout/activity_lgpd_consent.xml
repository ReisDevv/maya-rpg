<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/maya_bg_bege">

    <TextView
        android:id="@+id/tvLgpdTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Termo de uso e LGPD"
        android:textColor="@color/maya_dark_teal"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginTop="48dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvLgpdSubtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Para continuar, leia e aceite os termos abaixo."
        android:textColor="@color/maya_gray_stroke"
        android:textSize="14sp"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvLgpdTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ScrollView
        android:id="@+id/scrollLgpd"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="16dp"
        android:background="@android:color/white"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvLgpdSubtitle"
        app:layout_constraintBottom_toTopOf="@id/cbLgpd"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lineSpacingMultiplier="1.4"
            android:textColor="#333333"
            android:textSize="13sp"
            android:text="A Clínica Maya Yoshiko Yamamoto coleta apenas os dados necessários para o seu acompanhamento clínico de RPG (Reeducação Postural Global), respeitando a Lei Geral de Proteção de Dados (LGPD - Lei 13.709/2018).\n\nDados tratados: nome, CPF, e-mail, telefone, observações clínicas, registros de execução de exercícios e indicadores de evolução (dor, mobilidade, adesão).\n\nFinalidade: prestar o serviço de RPG, organizar prontuários, prescrever exercícios e acompanhar a sua evolução.\n\nCompartilhamento: seus dados não são compartilhados com terceiros sem o seu consentimento, exceto por obrigação legal.\n\nRetenção: os dados clínicos são retidos pelo prazo mínimo exigido pela legislação aplicável e podem ser apagados mediante solicitação ao DPO da clínica.\n\nDireitos do titular: você pode, a qualquer momento, solicitar acesso, correção ou exclusão dos seus dados pelo canal de atendimento da clínica.\n\nAo continuar, você confirma que leu e concorda com este termo." />
    </ScrollView>

    <CheckBox
        android:id="@+id/cbLgpd"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:text="Li e concordo com os termos de uso e LGPD."
        app:layout_constraintBottom_toTopOf="@id/btnAccept"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnAccept"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="32dp"
        android:text="Aceitar e continuar"
        android:textColor="@android:color/white"
        android:textStyle="bold"
        android:enabled="false"
        android:backgroundTint="@color/maya_dark_teal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
