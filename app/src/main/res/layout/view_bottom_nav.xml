<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNav"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:background="@drawable/bg_bottom_nav_pill"
    android:elevation="8dp">

    <ImageView
        android:id="@+id/navHome"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:stateListAnimator="@animator/nav_icon_scale"
        android:contentDescription="@string/content_desc_nav_home"
        android:padding="24dp"
        android:src="@drawable/vector_home"
        app:layout_constraintEnd_toStartOf="@id/navExercises"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="@color/white" />

    <ImageView
        android:id="@+id/navExercises"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:stateListAnimator="@animator/nav_icon_scale"
        android:contentDescription="@string/content_desc_nav_exercises"
        android:padding="20dp"
        android:src="@drawable/vector_exercises"
        app:layout_constraintEnd_toStartOf="@id/navEvolution"
        app:layout_constraintStart_toEndOf="@id/navHome"
        app:tint="@color/white" />

    <ImageView
        android:id="@+id/navEvolution"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:stateListAnimator="@animator/nav_icon_scale"
        android:contentDescription="@string/content_desc_nav_evolution"
        android:padding="24dp"
        android:src="@drawable/arquivo_grafico_linha_1"
        app:layout_constraintEnd_toStartOf="@id/navMore"
        app:layout_constraintStart_toEndOf="@id/navExercises"
        app:tint="@color/white" />

    <ImageView
        android:id="@+id/navMore"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:stateListAnimator="@animator/nav_icon_scale"
        android:contentDescription="@string/content_desc_nav_more"
        android:padding="24dp"
        android:src="@drawable/aplicativos_2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/navEvolution"
        app:tint="@color/white" />

</androidx.constraintlayout.widget.ConstraintLayout>
