<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".MayaApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_launcher_background"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher_foreground"
        android:supportsRtl="true"
    android:networkSecurityConfig="@xml/network_security_config"
    android:theme="@style/Theme.MayaRPG">

        <activity
            android:name=".ui.splash.SplashActivity"
            android:theme="@style/Theme.MayaRPG.NoActionBar.FullScreen"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.auth.LoginActivity" />
        <activity android:name=".ui.auth.ChangePasswordActivity" />
        <activity android:name=".ui.auth.RecoverPasswordActivity" />
        <activity android:name=".ui.home.HomeActivity" />
        <activity android:name=".ui.exercises.ExercisePlanActivity" />
        <activity android:name=".ui.exercises.ExerciseDetailActivity" />
        <activity android:name=".ui.exercises.ExerciseMediaActivity" />
        <activity android:name=".ui.exercises.RegisterPlanActivity" />
        <activity android:name=".ui.exercises.CheckInSuccessActivity" />
        <activity android:name=".ui.evolution.EvolutionActivity" />
        <activity android:name=".ui.profile.ProfileActivity" />
        <activity android:name=".ui.profile.EditProfileActivity" />
        <activity android:name=".ui.schedule.ScheduleActivity" />
        <activity android:name=".ui.schedule.AgendaActivity" />
        <activity android:name=".ui.chat.ChatListActivity" />
        <activity android:name=".ui.chat.ChatActivity" />
        <activity android:name=".ui.auth.LgpdConsentActivity" />
        <activity android:name=".ui.notifications.NotificationsActivity" />

        <service
            android:name=".fcm.MayaFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>
