<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivWakeIcon"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="Icone servidor dormindo"
        android:src="@drawable/bg_placeholder_icon"
        android:tint="#2B7A8C"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvWakeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⏱️ Servidor acordando…"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A4F5C"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/ivWakeIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvWakeMessage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="O servidor está em hibernação (plano gratuito). Isso pode levar até 60 segundos."
        android:textSize="14sp"
        android:textColor="#666"
        android:gravity="center"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/tvWakeTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <ProgressBar
        android:id="@+id/progressWakeUp"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/tvWakeMessage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvWakeUpCounter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Aguarde 60s (servidor acordando)..."
        android:textSize="14sp"
        android:textColor="#2B7A8C"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toBottomOf="@id/progressWakeUp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <Button
        android:id="@+id/btnWakeCancel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="Cancelar"
        android:backgroundTint="#E8845C"
        app:layout_constraintTop_toBottomOf="@id/tvWakeUpCounter"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnWakeRetry" />

    <Button
        android:id="@+id/btnWakeRetry"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Tentar agora"
        android:backgroundTint="#2B7A8C"
        app:layout_constraintTop_toBottomOf="@id/tvWakeUpCounter"
        app:layout_constraintStart_toEndOf="@id/btnWakeCancel"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
