<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:id="@+id/mainScrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNavContainer"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="32dp"
            android:paddingBottom="100dp">

            <!-- Header Section -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatar"
                android:layout_width="65dp"
                android:layout_height="65dp"
                android:layout_marginStart="32dp"
                android:background="#F5F5F5"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_person"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:shapeAppearanceOverlay="@style/ShapeAppearance.Maya.RoundedCircle"
                app:tint="@color/maya_nav_teal" />

            <TextView
                android:id="@+id/tvWelcome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="@string/home_welcome"
                android:textColor="#757575"
                android:textSize="12sp"
                app:layout_constraintBottom_toTopOf="@id/tvUserName"
                app:layout_constraintStart_toEndOf="@id/ivAvatar"
                app:layout_constraintTop_toTopOf="@id/ivAvatar"
                app:layout_constraintVertical_chainStyle="packed" />

            <TextView
                android:id="@+id/tvUserName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Olá, Sandra Lima"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="@id/ivAvatar"
                app:layout_constraintStart_toStartOf="@id/tvWelcome"
                app:layout_constraintTop_toBottomOf="@id/tvWelcome" />

            <FrameLayout
                android:id="@+id/notificationBell"
                android:layout_width="55dp"
                android:layout_height="55dp"
                android:layout_marginEnd="32dp"
                app:layout_constraintBottom_toBottomOf="@id/ivAvatar"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="@id/ivAvatar">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivNotification"
                    android:layout_width="55dp"
                    android:layout_height="55dp"
                    android:background="#E6D5B8"
                    android:padding="12dp"
                    android:scaleType="centerInside"
                    android:src="@drawable/ic_settings_bell"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.Maya.RoundedCircle"
                    app:tint="@color/black" />

                <View
                    android:id="@+id/notificationBadge"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="4dp"
                    android:background="@drawable/bg_pill_red"
                    android:visibility="gone" />

            </FrameLayout>

            <View
                android:id="@+id/headerDivider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="#EEEEEE"
                app:layout_constraintTop_toBottomOf="@id/ivAvatar" />

            <!-- Evolution Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardEvolution"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="#84D1E1"
                app:cardCornerRadius="25dp"
                app:cardElevation="4dp"
                app:rippleColor="#33FFFFFF"
                app:layout_constraintTop_toBottomOf="@id/headerDivider">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvEvolutionTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="16dp"
                        android:text="Sua Evolução Semanal"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:shadowColor="#000000"
                        android:shadowDx="0"
                        android:shadowDy="2"
                        android:shadowRadius="1"
                        app:layout_constraintEnd_toStartOf="@id/evolutionProgressContainer"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/tvConsistency"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/home_consistency_message"
                        android:textColor="@color/white"
                        android:textSize="13sp"
                        app:layout_constraintEnd_toEndOf="@id/tvEvolutionTitle"
                        app:layout_constraintStart_toStartOf="@id/tvEvolutionTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvEvolutionTitle" />

                    <TextView
                        android:id="@+id/tvNextAppointment"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        app:layout_constraintEnd_toEndOf="@id/tvEvolutionTitle"
                        app:layout_constraintStart_toStartOf="@id/tvEvolutionTitle"
                        app:layout_constraintTop_toBottomOf="@id/tvConsistency" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/evolutionProgressContainer"
                        android:layout_width="120dp"
                        android:layout_height="120dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ProgressBar
                            android:id="@+id/pbEvolution"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:indeterminate="false"
                            android:max="100"
                            android:progress="0"
                            android:progressDrawable="@drawable/bg_progress_ring"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvDays"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="@string/home_days_count"
                            android:textColor="@color/black"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Access Plan Section -->
            <TextView
                android:id="@+id/tvAccessPlanLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Acesse Seu Plano"
                android:textColor="@color/black"
                android:textSize="24sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cardEvolution" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPostural"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="24dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:rippleColor="#1A000000"
                app:layout_constraintEnd_toStartOf="@id/cardBalance"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tvAccessPlanLabel">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvPosturalTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:minLines="2"
                        android:text="Reeducação Postural Semanal"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/ivPostural"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/maya_inicial_mask_group_1"
                        app:layout_constraintTop_toBottomOf="@id/tvPosturalTitle"
                        tools:layout_editor_absoluteX="16dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartPostural"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="#F07167"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:stateListAnimator="@animator/button_scale"
                        android:text="INICIAR"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        app:cornerRadius="20dp"
                        app:layout_constraintTop_toBottomOf="@id/ivPostural" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBalance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="24dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="28dp"
                app:cardElevation="6dp"
                app:rippleColor="#1A000000"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/cardPostural"
                app:layout_constraintTop_toTopOf="@id/cardPostural">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvBalanceTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:minLines="2"
                        android:text="Equilíbrio e Postura: Coluna Integrada"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/ivBalance"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="8dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/maya_inicial_mask_group_2"
                        app:layout_constraintTop_toBottomOf="@id/tvBalanceTitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnStartBalance"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="#F07167"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:stateListAnimator="@animator/button_scale"
                        android:text="INICIAR"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        app:cornerRadius="20dp"
                        app:layout_constraintTop_toBottomOf="@id/ivBalance" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Schedule Week Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWeekSchedule"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginTop="32dp"
                app:cardBackgroundColor="#F2E9DE"
                app:cardCornerRadius="25dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/cardPostural">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvScheduleTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="Agendamentos da Semana"
                        android:textColor="@color/maya_brown"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        app:layout_constraintEnd_toStartOf="@id/ivSchedulePrev"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:id="@+id/ivSchedulePrev"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_marginEnd="8dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:src="@drawable/ic_arrow_back"
                        app:layout_constraintBottom_toBottomOf="@id/tvScheduleTitle"
                        app:layout_constraintEnd_toStartOf="@id/ivScheduleNext"
                        app:layout_constraintTop_toTopOf="@id/tvScheduleTitle"
                        app:tint="@color/maya_brown" />

                    <ImageView
                        android:id="@+id/ivScheduleNext"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:clickable="true"
                        android:focusable="true"
                        android:src="@drawable/ic_arrow_forward"
                        app:layout_constraintBottom_toBottomOf="@id/tvScheduleTitle"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@id/tvScheduleTitle"
                        app:tint="@color/maya_brown" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/rowDays"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:layout_constraintTop_toBottomOf="@id/tvScheduleTitle">

                        <TextView
                            android:id="@+id/tvDay1"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="SEG\n07"
                            android:textColor="@color/black"
                            android:textSize="11sp"
                            app:layout_constraintEnd_toStartOf="@id/tvDay2"
                            app:layout_constraintHorizontal_weight="1"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvDay2"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="TER\n08"
                            android:textColor="@color/black"
                            android:textSize="11sp"
                            app:layout_constraintEnd_toStartOf="@id/tvDay3"
                            app:layout_constraintHorizontal_weight="1"
                            app:layout_constraintStart_toEndOf="@id/tvDay1"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvDay3"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingVertical="8dp"
                            android:text="QUA\n09"
                            android:textColor="@color/black"
                            android:textSize="11sp"
                            android:background="@drawable/bg_day_selected"
                            app:layout_constraintEnd_toStartOf="@id/tvDay4"
                            app:layout_constraintHorizontal_weight="1"
                            app:layout_constraintStart_toEndOf="@id/tvDay2"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvDay4"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:text="QUI\n10"
                            android:textColor="@color/black"
                            android:textSize="11sp"
                            app:layout_constraintEnd_toStartOf="@id/tvDay5"
                            app:layout_constraintHorizontal_weight="1"
                            app:layout_constraintStart_toEndOf="@id/tvDay3"
                            app:layout_constraintTop_toTopOf="parent" />

                        <TextView
                            android:id="@+id/tvDay5"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingVertical="8dp"
                            android:text="SEX\n11"
                            android:textColor="@color/black"
                            android:textSize="11sp"
                            android:background="@drawable/bg_day_selected"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_weight="1"
                            app:layout_constraintStart_toEndOf="@id/tvDay4"
                            app:layout_constraintTop_toTopOf="parent" />
                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Painel de detalhe do dia selecionado -->
                    <View
                        android:id="@+id/dividerDayDetail"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:background="#D9C9B6"
                        android:visibility="gone"
                        app:layout_constraintTop_toBottomOf="@id/rowDays" />

                    <LinearLayout
                        android:id="@+id/layoutDayDetail"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="vertical"
                        android:visibility="gone"
                        app:layout_constraintTop_toBottomOf="@id/dividerDayDetail">

                        <TextView
                            android:id="@+id/tvDayDetailEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:paddingVertical="8dp"
                            android:text="Nenhuma consulta neste dia"
                            android:textColor="#8B6E5B"
                            android:textSize="13sp" />

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:id="@+id/cardDayAppointment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_day_appointment"
                            android:padding="12dp"
                            android:visibility="gone">

                            <TextView
                                android:id="@+id/tvDayApptTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/maya_dark_teal"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/tvDayApptStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textSize="13sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/tvDayApptTime" />

                            <TextView
                                android:id="@+id/tvDayApptType"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:textColor="#8B6E5B"
                                android:textSize="12sp"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/tvDayApptStatus" />

                        </androidx.constraintlayout.widget.ConstraintLayout>

                    </LinearLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Horizontal Action Cards -->
            <HorizontalScrollView
                android:id="@+id/horizontalActions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:clipToPadding="false"
                android:paddingHorizontal="24dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/cardWeekSchedule">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardSchedule"
                        android:layout_width="160dp"
                        android:layout_height="110dp"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="#84D1E1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:rippleColor="#33FFFFFF">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tvActionScheduleTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="@string/home_card_schedule_title"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                app:layout_constraintEnd_toStartOf="@id/ivActionScheduleIcon"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ImageView
                                android:id="@+id/ivActionScheduleIcon"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_nav_menu_grid"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="@color/white" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#4DFFFFFF"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp"
                                android:text="@string/home_card_schedule_cta"
                                android:textColor="@color/white"
                                android:textSize="11sp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Dúvida Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardChat"
                        android:layout_width="160dp"
                        android:layout_height="110dp"
                        android:layout_marginEnd="12dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="#F7A591"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:rippleColor="#33FFFFFF">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tvActionChatTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="@string/home_card_chat_title"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                app:layout_constraintEnd_toStartOf="@id/ivActionChatIcon"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ImageView
                                android:id="@+id/ivActionChatIcon"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/maya_inicial_vector_2"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="@color/white" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#4DFFFFFF"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="2dp"
                                android:text="@string/home_card_chat_cta"
                                android:textColor="@color/white"
                                android:textSize="11sp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Agenda Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardAgenda"
                        android:layout_width="160dp"
                        android:layout_height="110dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardBackgroundColor="#5AB8C4"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        app:rippleColor="#33FFFFFF">

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:padding="12dp">

                            <TextView
                                android:id="@+id/tvActionAgendaTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:text="@string/home_card_agenda_title"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                app:layout_constraintEnd_toStartOf="@id/ivActionAgendaIcon"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <ImageView
                                android:id="@+id/ivActionAgendaIcon"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/img_aplicativos2"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintTop_toTopOf="parent"
                                app:tint="@color/white" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="#4DFFFFFF"
                                android:paddingHorizontal="10dp"
                                android:paddingVertical="4dp"
                                android:text="@string/home_card_agenda_cta"
                                android:textColor="@color/white"
                                android:textSize="11sp"
                                app:layout_constraintBottom_toBottomOf="parent"
                                app:layout_constraintStart_toStartOf="parent" />
                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>
            </HorizontalScrollView>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <include
        android:id="@+id/bottomNavContainer"
        layout="@layout/view_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_bottom_nav"
        android:backgroundTint="#01577A"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
